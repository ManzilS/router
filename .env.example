# AI Router — Configuration
# Copy this to .env and fill in your values.
# Adapter-specific settings live in plugins.yaml.

# Server
ROUTER_HOST=127.0.0.1
ROUTER_PORT=8080
ROUTER_LOG_LEVEL=INFO

# Dev mode — enables verbose logging, /docs endpoint, error details in responses
ROUTER_DEV_MODE=false

# Default adapter (must match a name in plugins.yaml)
ROUTER_DEFAULT_ADAPTER=lmstudio
ROUTER_MAX_LOOPS=3

# Plugin config path
ROUTER_PLUGINS_CONFIG=plugins.yaml

# Data directory for plugins that need persistence
ROUTER_DATA_DIR=~/.ai-router

# --- Production hardening ---

# CORS — comma-separated origins, or "*" for all
ROUTER_CORS_ORIGINS=*

# Request timeout (seconds)
ROUTER_REQUEST_TIMEOUT=120.0

# Max request body size (bytes) — default 10MB
ROUTER_MAX_BODY_SIZE=10485760

# Authentication — if set, requires Bearer token on /v1/* endpoints
ROUTER_API_KEY=

# Rate limiting — requests per minute per IP (0 = disabled)
ROUTER_RATE_LIMIT_RPM=0
