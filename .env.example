# AI Gateway Brain — Configuration
# Copy this to .env and fill in your values

# Server
AIGW_HOST=127.0.0.1
AIGW_PORT=8080
AIGW_LOG_LEVEL=INFO

# Default adapter: openai | ollama | gemini
AIGW_DEFAULT_ADAPTER=openai
AIGW_MAX_LOOPS=3

# OpenAI / LMStudio
AIGW_OPENAI_BASE_URL=https://api.openai.com/v1
AIGW_OPENAI_API_KEY=sk-...

# Ollama (local)
AIGW_OLLAMA_BASE_URL=http://localhost:11434

# Google Gemini
AIGW_GEMINI_API_KEY=
AIGW_GEMINI_MODEL=gemini-2.0-flash

# Fallback chain (try adapters in order if one fails)
# Leave empty to disable. Example: ["openai", "ollama", "gemini"]
AIGW_FALLBACK_CHAIN=[]
AIGW_FALLBACK_FAILURE_THRESHOLD=3
AIGW_FALLBACK_RECOVERY_TIMEOUT=60.0

# Feature toggles
AIGW_ENABLE_RAG=true
AIGW_ENABLE_EARLY_EXIT=true
AIGW_ENABLE_LOGGER=true
